# Copy this file to .env and fill in real values

# Firebase project ID (find in Firebase Console → Project settings)
FIREBASE_PROJECT_ID=embah-yasin-keluarga

# Path to service account JSON key file. Download from:
# Firebase Console → Project settings → Service accounts → Generate new private key
# DO NOT commit this file to git. Add to .gitignore.
GOOGLE_APPLICATION_CREDENTIALS=./serviceAccountKey.json

# Web client config (for frontend Google sign-in)
# Find in Firebase Console → Project settings → General → Your apps → Web app config
FIREBASE_WEB_API_KEY=AIzaSy...
FIREBASE_AUTH_DOMAIN=embah-yasin-keluarga.firebaseapp.com

# Flask
FLASK_SECRET_KEY=change-me-to-a-random-string
FLASK_ENV=development
